# Copy this file to .env and fill in your Supabase values.
# Find your connection string in:
#   Supabase → Project Settings → Database → URI (use "Transaction" mode for serverless)

# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# IMPORTANT: if your password has special chars like @, encode them (e.g. @ -> %40)
DATABASE_URL=postgresql://postgres:[DB_PASSWORD_ENCODED]@db.[PROJECT_REF].supabase.co:5432/postgres
# Server config
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# CORS — add your frontend origin if needed
ALLOWED_ORIGINS=http://localhost,http://localhost:8000
